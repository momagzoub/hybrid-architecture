# Project data — never commit these. Leading slash = top-level only,
# so `docs/results/` (published artefacts) remains tracked.
/data/
/results/
*.pt
*.pth
*.safetensors
*.bin
# Allow committed probe checkpoints — small (~50KB each), the shipping artifact.
!src/hybrid_arch/probe_checkpoints/*.pt

